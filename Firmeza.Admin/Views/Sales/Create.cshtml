@model Firmeza.Domain.Models.Dtos.CreateSaleDto

@{
    ViewData["Title"] = "New Sale";
}

<div class="page-header">
    <div>
        <div class="page-title">New Sale</div>
        <div class="page-subtitle">Register a new sale</div>
    </div>
</div>

<div class="form-card">
    <form asp-controller="Sales" asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:16px"></div>

        <div class="form-group">
            <label asp-for="ClientId" class="form-label">Client ID</label>
            <input asp-for="ClientId" type="number" class="form-control" />
            <span asp-validation-for="ClientId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Status" class="form-label">Status</label>
            <input asp-for="Status" type="text" class="form-control" placeholder="e.g. Pending, Completed" />
            <span asp-validation-for="Status" class="text-danger"></span>
        </div>

        <div class="form-grid-2">
            <div class="form-group">
                <label asp-for="SubTotal" class="form-label">SubTotal</label>
                <input asp-for="SubTotal" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="SubTotal" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Tax" class="form-label">Tax</label>
                <input asp-for="Tax" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="Tax" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Total" class="form-label">Total</label>
            <input asp-for="Total" type="number" step="0.01" class="form-control" />
            <span asp-validation-for="Total" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Sale</button>
            <a asp-action="Index" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>
