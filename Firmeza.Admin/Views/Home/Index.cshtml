@model Firmeza.Domain.Models.Dtos.DashboardDto

@{
    ViewData["Title"] = "Dashboard";
}

<div class="metric-grid">
    <div class="metric-card">
        <div class="metric-label">Total Products</div>
        <div class="metric-value accent">@Model.ProductTotalAmount</div>
    </div>
    <div class="metric-card">
        <div class="metric-label">Total Clients</div>
        <div class="metric-value">@Model.ClientTotalAmount</div>
    </div>
    <div class="metric-card">
        <div class="metric-label">Total Sales</div>
        <div class="metric-value">@Model.SaleTotalAmount</div>
    </div>
</div>
