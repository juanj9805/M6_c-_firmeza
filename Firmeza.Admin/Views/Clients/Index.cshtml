@model List<Firmeza.Domain.Models.Dtos.ClientDto>

@{
    ViewData["Title"] = "Clients";
}

<div class="page-header">
    <div>
        <div class="page-title">Clients</div>
        <div class="page-subtitle">Manage your client accounts</div>
    </div>
    <a class="btn btn-primary" asp-action="Create">+ New Client</a>
</div>

@if (!Model.Any())
{
    <div class="table-wrapper">
        <div class="empty-state">
            <div class="empty-state-title">No Clients Yet</div>
            <div class="empty-state-sub">Register your first client to get started.</div>
            <a asp-action="Create" class="btn btn-primary">+ New Client</a>
        </div>
    </div>
}
else
{
<div class="table-wrapper">
    <table class="data-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Address</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var client in Model)
            {
                <tr>
                    <td>@client.Name</td>
                    <td><span class="mono">@client.Email</span></td>
                    <td><span class="mono">@client.Phone</span></td>
                    <td>@client.Address</td>
                    <td>
                        @if (client.IsActive)
                        {
                            <span class="badge badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-danger">Inactive</span>
                        }
                    </td>
                    <td>
                        <div class="actions">
                            <a asp-action="Detail" asp-route-id="@client.Id" class="btn btn-ghost btn-sm">View</a>
                            <a asp-action="Edit" asp-route-id="@client.Id" class="btn btn-ghost btn-sm">Edit</a>
                            <form asp-action="Delete" asp-route-id="@client.Id" method="post" style="margin:0">
                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
}
