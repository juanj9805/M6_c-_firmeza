@model Firmeza.Domain.Models.Dtos.CreateClientDto

@{
    ViewData["Title"] = "New Client";
}

<div class="page-header">
    <div>
        <div class="page-title">New Client</div>
        <div class="page-subtitle">Register a new client account</div>
    </div>
</div>

<div class="form-card">
    <form asp-controller="Clients" asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:16px"></div>

        <div class="form-group">
            <label asp-for="Name" class="form-label">Name</label>
            <input asp-for="Name" type="text" class="form-control" placeholder="Full name" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email" class="form-label">Email</label>
            <input asp-for="Email" type="email" class="form-control" placeholder="email@example.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Phone" class="form-label">Phone</label>
            <input asp-for="Phone" type="text" class="form-control" placeholder="+1 000 000 0000" />
            <span asp-validation-for="Phone" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Address" class="form-label">Address</label>
            <input asp-for="Address" type="text" class="form-control" placeholder="Street, City" />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Client</button>
            <a asp-action="Index" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>

