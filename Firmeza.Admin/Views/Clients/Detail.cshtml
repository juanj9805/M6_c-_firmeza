@model Firmeza.Domain.Models.Dtos.ClientDto

@{
    ViewData["Title"] = "Client Detail";
}

<h1>Client Detail</h1>

<dl>
    <dt>Id</dt>
    <dd>@Model.Id</dd>
    <dt>Name</dt>
    <dd>@Model.Name</dd>
    <dt>Email</dt>
    <dd>@Model.Email</dd>
    <dt>Phone</dt>
    <dd>@Model.Phone</dd>
    <dt>Address</dt>
    <dd>@Model.Address</dd>
    <dt>Active</dt>
    <dd>@Model.IsActive</dd>
    <dt>Created</dt>
    <dd>@Model.CreatedAt</dd>
    <dt>Updated</dt>
    <dd>@Model.UpdatedAt</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>
