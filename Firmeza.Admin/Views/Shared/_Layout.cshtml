<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Firmeza</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="admin-layout">

    <aside class="sidebar">
        <div class="sidebar-brand">
            <a asp-controller="Home" asp-action="Index">
                <span class="sidebar-brand-name">Firmeza</span>
                <span class="sidebar-brand-sub">Admin Panel</span>
            </a>
        </div>
        <nav class="sidebar-nav">
            <div class="sidebar-section-label">Overview</div>
            <a asp-controller="Home" asp-action="Index"
               class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
               aria-current="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "page" : null)">
                <svg class="sidebar-icon" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                    <rect x="1" y="1" width="6" height="6" rx="1"/>
                    <rect x="9" y="1" width="6" height="6" rx="1"/>
                    <rect x="1" y="9" width="6" height="6" rx="1"/>
                    <rect x="9" y="9" width="6" height="6" rx="1"/>
                </svg>
                Dashboard
            </a>
            <div class="sidebar-section-label" style="margin-top:16px">Management</div>
            <a asp-controller="Products" asp-action="Index"
               class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")"
               aria-current="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "page" : null)">
                <svg class="sidebar-icon" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                    <path d="M8 1L1 4.5v7L8 15l7-3.5v-7L8 1zm0 1.8l5 2.5-5 2.5-5-2.5 5-2.5zM2 6.8l5 2.5v4.4L2 11.2V6.8zm6 6.9V9.3l5-2.5v4.4L8 13.7z"/>
                </svg>
                Products
            </a>
            <a asp-controller="Clients" asp-action="Index"
               class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Clients" ? "active" : "")"
               aria-current="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Clients" ? "page" : null)">
                <svg class="sidebar-icon" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                    <path d="M8 7a3 3 0 100-6 3 3 0 000 6zm-5 6a5 5 0 0110 0H3z"/>
                </svg>
                Clients
            </a>
        </nav>
        <div class="sidebar-footer">&copy; 2026 Firmeza</div>
    </aside>

    <div class="main-content">
        <div class="topbar">
            <span class="topbar-title">@ViewData["Title"]</span>
        </div>
        <div class="page-content">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger" role="alert">@TempData["Error"]</div>
            }
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success" role="alert">@TempData["Success"]</div>
            }
            @RenderBody()
        </div>
    </div>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
