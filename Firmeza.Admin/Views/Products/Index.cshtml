@model List<Firmeza.Domain.Models.Dtos.ProductDto>

@{
    ViewData["Title"] = "Products";
}

<div class="page-header">
    <div>
        <div class="page-title">Products</div>
        <div class="page-subtitle">Manage your product catalog</div>
    </div>
    <div style="display:flex;gap:0.5rem">
        <a class="btn btn-ghost" asp-action="Import">Import Excel</a>
        <a class="btn btn-primary" asp-action="Create">+ New Product</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="table-wrapper">
        <div class="empty-state">
            <div class="empty-state-title">No Products Yet</div>
            <div class="empty-state-sub">Add your first product to get started.</div>
            <a asp-action="Create" class="btn btn-primary">+ New Product</a>
        </div>
    </div>
}
else
{
<div class="table-wrapper">
    <table class="data-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>SKU</th>
                <th>Type</th>
                <th>Stock</th>
                <th>Price</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>@product.Name</td>
                    <td><span class="mono">@product.SKU</span></td>
                    <td>@product.Type</td>
                    <td><span class="mono">@product.Stock</span></td>
                    <td><span class="mono">$@product.Price.ToString("N2")</span></td>
                    <td>
                        @if (product.IsActive)
                        {
                            <span class="badge badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-danger">Inactive</span>
                        }
                    </td>
                    <td>
                        <div class="actions">
                            <a asp-action="Detail" asp-route-id="@product.Id" class="btn btn-ghost btn-sm">View</a>
                            <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-ghost btn-sm">Edit</a>
                            <form asp-action="Delete" asp-route-id="@product.Id" method="post" style="margin:0">
                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
}
